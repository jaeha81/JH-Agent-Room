{
  "manifest_version": 3,
  "name": "JH Agent Room Share",
  "version": "0.1.0",
  "description": "Share the current page into JH Agent Room routing loops.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Share to Agent Room"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://127.0.0.1:3100/*",
    "http://localhost:3100/*"
  ]
}
